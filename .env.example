# Copy this file to .env (gitignored) and fill in real values.
# Gates that need credentials auto-load .env from the project root.
#
# Alternative populator: Infisical. The repo is Infisical-agnostic; if your
# workspace already holds these values, run `just infcl-dev` (wraps `just
# dev` with `infisical run`). Env vars from Infisical override .env per
# pydantic-settings precedence, so you can leave .env empty when Infisical
# is the source of truth.

# GCP Cloud Billing Catalog API key.
# Required for gates/gcp.py. The catalog data is public, but Google requires
# an API key on every request for quota tracking.
#
# To provision:
#   1. Create or pick a GCP project in https://console.cloud.google.com/
#   2. Enable the "Cloud Billing API" for that project.
#   3. Create an API key under APIs & Services > Credentials.
#   4. Restrict the key to the Cloud Billing API only.
#   5. Paste the key value below.
GCP_API_KEY=

# AWS gate uses the public Price List Bulk API; no credentials required.
# Azure gate uses the public Retail Prices API; no credentials required.

# ---------------------------------------------------------------------------
# API process: HTTP surface (read by api/config.py and the `just api` recipe).
# ---------------------------------------------------------------------------

# Port the FastAPI app binds. Integer. Default 8000.
API_PORT=8000

# Browser origins allowed by CORS. Comma-separated list of origins.
# Default covers the local frontend dev server on port 3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Agent model provider (ADR-0009). Any OpenAI-compatible endpoint; the agent
# uses the Chat Completions API, so a provider that only speaks Chat
# Completions works. Required to run the agent; the deterministic query API
# (compare/lookup/excerpt/health) runs without these.
# ---------------------------------------------------------------------------

# Base URL of the OpenAI-compatible endpoint, e.g.
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   http://localhost:11434/v1   (local server)
PROVIDER_BASE_URL=

# API key for that endpoint.
PROVIDER_API_KEY=

# Model identifier as the provider names it, e.g. gpt-4.1, or a namespaced id
# like anthropic/claude-... on aggregators such as OpenRouter.
MODEL_NAME=

# ---------------------------------------------------------------------------
# Observability (ADR-0010). OpenTelemetry traces emitted as JSON lines on disk;
# any OTel-aware backend can ingest the file later. Off-switch defaults to on.
# ---------------------------------------------------------------------------

# Global on/off for the trace pipeline. When false, no exporter is registered
# and the FastAPI app is not instrumented.
OTEL_ENABLED=true

# JSONL output path. Relative paths resolve against PROJECT_ROOT.
OTEL_JSONL_PATH=var/traces/traces.jsonl

# Mirror spans to stderr alongside the file. Useful in dev; noisy in prod.
OTEL_CONSOLE_EXPORT=false

# OTel-standard env name (see opentelemetry semantic-conventions). When true,
# spans carry user message text and assistant final output. Off by default to
# keep on-disk traces free of accidental PII.
OTEL_CAPTURE_CONTENT=false

# ---------------------------------------------------------------------------
# Budget enforcement (ADR-0011). Five server-trusted caps in front of /assistant:
# global daily tokens, per-client request/token rate (keyed by salted-hash IP),
# per-session cumulative tokens (keyed by the finops_session_id cookie), per-turn
# tokens, and a max_turns iteration cap. Tokens are the primitive; USD is a
# derived view via api.observability.PRICE_TABLE.
# ---------------------------------------------------------------------------

# Off-switch. When false, no middleware blocking, no SQLite store, no cookie.
# Useful for tests and local dev that wants to skip the salt requirement.
BUDGET_ENABLED=true

# SQLite store for the three budget tables. Relative paths resolve against
# PROJECT_ROOT. Parent dir is created on first write.
BUDGET_DB_PATH=var/budgets.db

# Process secret combined with the UTC date to form the daily-rotating salt
# for client-id hashing. REQUIRED when BUDGET_ENABLED=true; the process
# refuses to boot without it. Use 32+ bytes of randomness, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
BUDGET_IP_HASH_SALT_SECRET=

# Global daily token cap across all users. Drains -> 503 with Retry-After
# pointing at the next UTC midnight. 10M tokens is ~$2-30/day depending on
# the model you point the agent at (cheaper for gpt-4o-mini, dearer for opus).
GLOBAL_DAILY_TOKEN_CAP=10000000

# Per-client request rate (HMAC'd IP key) measured in a rolling 60-second
# window. Once over, response is 429 with Retry-After to the window close.
CLIENT_RATE_REQUESTS_PER_MINUTE=30

# Per-client token rate measured in a rolling 3600-second window. Over -> 429.
CLIENT_RATE_TOKENS_PER_HOUR=200000

# Per-session cumulative token cap (input + output). Over -> in-thread
# "session limit reached" message + state.sessionLimitReached=true for the
# frontend banner. No retry; the user must start a new conversation.
SESSION_TOKEN_CAP=50000

# Idle TTL for the finops_session_id cookie, in minutes.
SESSION_IDLE_TIMEOUT_MINUTES=60

# Cookie attributes. session_cookie_name is the name as the browser stores it;
# session_cookie_secure should be true in production (HTTPS-only).
SESSION_COOKIE_NAME=finops_session_id
SESSION_COOKIE_SECURE=false

# Per-turn token cap. Hooks raise when the cumulative input+output for one
# Runner.run_streamed run reaches this; the visible thread shows
# "[turn stopped: ...]" and the trace records finops.budget.scope="turn".
TURN_TOKEN_CAP=20000

# Hard iteration cap on a single Runner.run_streamed. Belt-and-braces against
# a runaway agent loop independent of token consumption.
MAX_TURNS_PER_RUN=3

# Number of trusted reverse-proxy hops in front of FastAPI. 0 = trust
# request.client.host directly. Increase when behind nginx / Cloudflare /
# similar so the per-client key is the real client, not the proxy.
TRUSTED_PROXY_COUNT=0
