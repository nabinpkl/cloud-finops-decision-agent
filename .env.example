# Copy this file to .env (gitignored) and fill in real values.
# Gates that need credentials auto-load .env from the project root.

# GCP Cloud Billing Catalog API key.
# Required for gates/gcp.py. The catalog data is public, but Google requires
# an API key on every request for quota tracking.
#
# To provision:
#   1. Create or pick a GCP project in https://console.cloud.google.com/
#   2. Enable the "Cloud Billing API" for that project.
#   3. Create an API key under APIs & Services > Credentials.
#   4. Restrict the key to the Cloud Billing API only.
#   5. Paste the key value below.
GCP_API_KEY=

# AWS gate uses the public Price List Bulk API; no credentials required.
# Azure gate uses the public Retail Prices API; no credentials required.
