# Copy this file to .env (gitignored) and fill in local secrets.
#
# Keep this file sparse. Defaults live in backend settings classes; only put a
# value in .env when it is a secret or an intentional environment override.
#
# Alternative populator: Infisical. The repo is Infisical-agnostic; if your
# workspace already holds these values, run `just infcl-dev` (wraps `just dev`
# with `infisical run`). Env vars from Infisical override .env per
# pydantic-settings precedence.

# ---------------------------------------------------------------------------
# Provider ingest credentials.
# ---------------------------------------------------------------------------

# GCP Cloud Billing Catalog API key.
# Required only for `just fetch gcp` / `just fetch-all`. The catalog data is
# public, but Google requires an API key on every request for quota tracking.
#
# To provision:
#   1. Create or pick a GCP project in https://console.cloud.google.com/
#   2. Enable the "Cloud Billing API" for that project.
#   3. Create an API key under APIs & Services > Credentials.
#   4. Restrict the key to the Cloud Billing API only.
GCP_API_KEY=

# AWS, Azure, Oracle, Vultr, Linode, and IBM ingest use public no-auth
# endpoints in v0.

# ---------------------------------------------------------------------------
# Agent model provider.
# ---------------------------------------------------------------------------

# Required to run `/assistant` or `just smoke`. Deterministic endpoints
# (`compare`, `lookup`, `citation/excerpt`, `health`) do not need model creds.
PROVIDER_BASE_URL=
PROVIDER_API_KEY=
MODEL_NAME=

# Optional runtime overrides. Defaults:
#   AGENT_RUNTIME=deepagents
#   LANGCHAIN_REASONING_ROUNDTRIP=false
# Uncomment only when changing those defaults.
# AGENT_RUNTIME=openai_agents
# LANGCHAIN_REASONING_ROUNDTRIP=true

# ---------------------------------------------------------------------------
# Budget enforcement.
# ---------------------------------------------------------------------------

# Required when BUDGET_ENABLED=true, which is the code default. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
BUDGET_IP_HASH_SALT_SECRET=

# ---------------------------------------------------------------------------
# HTTP process.
# ---------------------------------------------------------------------------

# Port used by `just api` and `just dev` before Python settings are loaded.
API_PORT=8000

# Browser origins allowed by FastAPI CORS. Comma-separated list.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local-dev off switch. Leave unset in production.
# BUDGET_ENABLED=false

# ---------------------------------------------------------------------------
# Common deployment overrides.
# ---------------------------------------------------------------------------

# Code defaults:
#   OTEL_JSONL_PATH=var/traces/traces.jsonl
#   OTEL_CAPTURE_CONTENT=false
#   BUDGET_DB_PATH=var/budgets.db
#   SESSION_COOKIE_SECURE=false
#   TRUSTED_PROXY_COUNT=0
#
# Uncomment only when deployment differs from those defaults.
# OTEL_JSONL_PATH=var/traces/traces.jsonl
# OTEL_CONSOLE_EXPORT=true
# OTEL_CAPTURE_CONTENT=true
# BUDGET_DB_PATH=var/budgets.db
# SESSION_COOKIE_SECURE=true
# TRUSTED_PROXY_COUNT=1

# ---------------------------------------------------------------------------
# Advanced ingest/normalize overrides.
# ---------------------------------------------------------------------------

# These are code defaults and normally should not appear in .env. Uncomment only
# for a known provider/runtime issue or stricter CI policy.
# INGEST_STORE_ROOT=store
# INGEST_SNAPSHOT_FRESHNESS_HOURS=24
# INGEST_HTTP_TIMEOUT_SECONDS=120
# INGEST_HTTP_SHORT_TIMEOUT_SECONDS=60
# INGEST_HTTP_LARGE_TIMEOUT_SECONDS=600
# INGEST_HTTP_MAX_RETRIES=5
# INGEST_HTTP_INITIAL_BACKOFF_SECONDS=2
# INGEST_HTTP_MAX_BACKOFF_SECONDS=60
# INGEST_IBM_PRICING_CONCURRENCY=8
# NORMALIZE_ROW_DROP_HARD_FAIL_PCT=50
# NORMALIZE_ROW_DROP_WARN_PCT=30
# NORMALIZE_CITATION_FAIL_HARD_FAIL_PCT=1
# NORMALIZE_CITATION_VERIFIER_SAMPLE_CAP=50
